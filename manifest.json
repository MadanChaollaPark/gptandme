{
  "manifest_version": 3,
  "name": "GPTandME",
  "version": "1.2.3",
  "description": "Counts prompts you send to supported AI chat sites and stores usage locally.",
  "permissions": ["storage", "webRequest", "activeTab", "alarms"],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://perplexity.ai/*",
    "*://www.perplexity.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GPTandME"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://chatgpt.com/*", "*://chat.openai.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://www.perplexity.ai/*"
      ],
      "js": ["shared.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}
